# SECURITY NOTE:
# - Any variable starting with VITE_ is bundled in frontend code and is publicly visible.
# - Never place private API keys or secrets in VITE_ variables.

# Frontend (Vite)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_CHAT_API_URL=http://localhost:3000

# Backend CORS allowlist (comma-separated)
ALLOWED_ORIGINS=https://shizu0n.vercel.app,https://shizu0n.github.io,http://localhost:3000,http://127.0.0.1:3000

# Backend — Google AI (Embeddings + Gemini 2.5 Flash primary chat)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Supabase RAG (api/chat.js and scripts/ingest.js)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_or_service_role_key

# Multi-Provider RAG Fallback Chain
# Provider 2: Groq — llama-3.3-70b-versatile (console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here

# Provider 3: OpenRouter — meta-llama/llama-3.1-8b-instruct:free (openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Provider 4: Cloudflare Workers AI — @cf/meta/llama-3-8b-instruct
# Account ID: dash.cloudflare.com (sidebar) | Token: dash.cloudflare.com/profile/api-tokens
CF_ACCOUNT_ID=your_cloudflare_account_id_here
CF_WORKERS_AI_TOKEN=your_cloudflare_workers_ai_token_here