{
  "name": "portifolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "test": "vitest run",
    "test:chat-cards": "vitest run src/components/__tests__/chatProjectCatalog.test.ts src/components/__tests__/chatProjectCardPolicy.test.ts",
    "test:chat-cards-ui": "node ./visual-qa/test-chat-card-context.cjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "security:check": "node ./scripts/security-check.js",
    "knowledge:build": "node ./scripts/build-chatbot-knowledge.js && node ./scripts/validate-chatbot-knowledge.js",
    "knowledge:validate": "node ./scripts/validate-chatbot-knowledge.js",
    "knowledge:ingest": "node --env-file=.env ./scripts/ingest.js",
    "preview": "vite preview",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "framer-motion": "^12.23.24",
    "lenis": "^1.3.21",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.6.2",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "supabase": "^2.92.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^4.1.4"
  }
}
